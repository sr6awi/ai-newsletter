# =============================================================================
# AI Newsletter Pipeline — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your credentials.
# See README.md for instructions on obtaining each key.
# =============================================================================

# --- Google Gemini API (free tier: 15 RPM / 1M tokens/day) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Microsoft Outlook / Office 365 Email Delivery ---
# Sender address (must match the authenticated SMTP account)
OUTLOOK_FROM_EMAIL=newsletter@yourcompany.com
# Recipient — use a distribution list or comma-separated addresses
OUTLOOK_TO_EMAIL=corporate@yourcompany.com
# SMTP credentials are configured in n8n UI (Settings > Credentials > SMTP)
# Host: smtp.office365.com | Port: 587 | Security: STARTTLS

# --- Google Sheets (used by n8n workflows for dedup storage) ---
# The spreadsheet ID from the URL: https://docs.google.com/spreadsheets/d/{THIS_PART}/edit
GOOGLE_SHEETS_ID=your_google_sheets_id_here
# Path to the service account JSON key file
GOOGLE_SERVICE_ACCOUNT_JSON=./service_account.json

# --- n8n Configuration ---
N8N_PORT=5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_this_password
# Encryption key for n8n credentials (generate with: openssl rand -hex 32)
N8N_ENCRYPTION_KEY=generate_a_random_hex_string_here

# --- Python Pipeline (SQLite alternative — no Google Sheets needed) ---
# Set to "sqlite" to use local SQLite DB, or "sheets" to use Google Sheets
STORAGE_BACKEND=sqlite
SQLITE_DB_PATH=./newsletter.db

# --- Optional: Override newsletter schedule (cron expression) ---
# Default for n8n: Monday 9 AM UTC
# NEWSLETTER_CRON=0 9 * * 1
